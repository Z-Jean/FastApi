# 复制为 .env 后填入真实配置（.env 不要提交到 Git）
# cp .env.example .env

# 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=fullstack_db

# JWT（生产环境务必更换，可用: openssl rand -hex 32）
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=2

# 应用
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# CORS（逗号分隔，不要有空格；生产环境改为你的前端地址）
CORS_ORIGINS=http://localhost:3000

# 生产环境示例：
# DEBUG=False
# CORS_ORIGINS=https://你的域名.com,http://你的域名.com
